{
	"docType":     "cv",
	"label":       "Curriculum Vitae",
	"version":     "2.0",
	"contentType": "CVData",
	"domPrefix":   "cv",

	"medium": {
		"pageSize": "A4",
		"pages": { "min": 1, "max": 2 }
	},

	"zones": {
		"id":        "root",
		"sizing":    { "type": "flex" },
		"direction": "vertical",
		"children": [
			{
				"id":            "header",
				"sizing":        { "type": "intrinsic" },
				"firstPageOnly": true,
				"variants": [
					{ "id": "full",    "label": "Full",    "default": true },
					{ "id": "compact", "label": "Compact"                  },
					{ "id": "minimal", "label": "Minimal"                  },
					{ "id": "strip",   "label": "Strip"                    }
				]
			},
			{
				"id":        "body",
				"sizing":    { "type": "flex" },
				"direction": "horizontal",
				"children": [
					{
						"id":     "sidebar",
						"sizing": { "type": "range", "minMm": 44, "maxMm": 70 }
					},
					{
						"id":        "main",
						"sizing":    { "type": "flex" },
						"direction": "vertical",
						"children": [
							{
								"id":     "main-body",
								"sizing": { "type": "flex" }
							},
							{
								"id":       "footer",
								"sizing":   { "type": "intrinsic" },
								"optional": true
							}
						]
					}
				]
			}
		]
	},

	"movableSections": [
		{
			"id":           "skills",
			"label":        "Skills",
			"defaultZone":  "sidebar",
			"allowedZones": ["sidebar", "footer"]
		},
		{
			"id":           "languages",
			"label":        "Languages",
			"defaultZone":  "sidebar",
			"allowedZones": ["sidebar", "footer"]
		},
		{
			"id":           "interests",
			"label":        "Interests",
			"defaultZone":  "sidebar",
			"allowedZones": ["sidebar", "footer"]
		}
	],

	"fixedSections": [
		{
			"id":    "education",
			"label": "Education",
			"zone":  "sidebar"
		},
		{
			"id":    "profile",
			"label": "Profile",
			"zone":  "header"
		}
	],

	"contentSplits": [
		{
			"id":         "work",
			"collection": "work",
			"zone":       "main-body",
			"minFirst":   1
		}
	]
}

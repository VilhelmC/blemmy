{
	"docType":     "letter",
	"label":       "Letter",
	"version":     "2.0",
	"contentType": "LetterData",
	"domPrefix":   "blemmy",

	"medium": {
		"pageSize": "A4",
		"pages": { "min": 1, "max": 1 }
	},

	"zones": {
		"id":        "root",
		"sizing":    { "type": "flex" },
		"direction": "vertical",
		"children": [
			{
				"id":            "header",
				"sizing":        { "type": "intrinsic" },
				"firstPageOnly": true
			},
			{
				"id":     "body",
				"sizing": { "type": "flex" }
			}
		]
	},

	"movableSections": [],
	"fixedSections":   [],
	"contentSplits":   []
}

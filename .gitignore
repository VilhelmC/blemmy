# ── Build outputs ────────────────────────────────────────────
node_modules/
dist/
.astro/

# ── Environment ───────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Personal data — never commit real CV content ──────────────
# Use src/data/cv-demo.json as the committed example.
# Keep your real CV files local or in a private repo.
src/data/cv-content.json
src/data/cv-*.json
!src/data/cv-demo.json

# ── Generated assets — reproduced by `npm run pdf` ────────────
public/*.pdf
public/*.jpg
public/*.jpeg
public/*.png
!public/blemmy.png

# ── Layout engine diagnostic reports (generated by test scripts) ─
docs/reports/*
!docs/reports/.gitkeep

# ── Local init playbook (not part of the published tree) ───────
REPO-INIT.md
v2.0.1-deployment-instructions.md

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.zip
.tmp-import/
.tmp-v201-zip/
.tmp-blemmy-zip/
.vscode/settings.json

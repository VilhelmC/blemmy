{
	"compilerOptions": {
		"target": "ES2020",
		"lib": [
			"ES2020",
			"DOM",
			"DOM.Iterable"
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@lib/*": [
				"src/lib/*"
			],
			"@data/*": [
				"src/data/*"
			],
			"@styles/*": [
				"src/styles/*"
			],
			"@renderer/*": [
				"src/renderer/*"
			],
			"@cv/*": [
				"src/types/*"
			],
			"@types/*": [
				"src/types/*"
			]
		},
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"useUnknownInCatchVariables": false
	},
	"include": [
		"src/**/*.ts",
		"vite.config.ts"
	],
	"exclude": [
		"vite.config.ts",
		"vitest.config.ts",
		"**/*.test.ts",
		"node_modules"
	]
}

VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Project Settings → API → anon (public) — long eyJ… JWT, no quotes
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY_FROM_SUPABASE_DASHBOARD
# Optional: [cv-auth] console logs during OAuth / PKCE
# VITE_AUTH_DEBUG=true
# Optional: same-tab OAuth (GitHub / Google; avoids popup PKCE / storage issues)
# VITE_OAUTH_USE_FULL_REDIRECT=true
#
# OAuth return URL: leave VITE_OAUTH_REDIRECT_ORIGIN UNSET unless you know you need it.
# By default the app uses the current page origin (blemmy.dev, localhost:5923, etc.).
# If you set e.g. http://localhost:5923 here, the Google/GitHub popup will always
# return there — nothing must listen on that host (npm run dev), or you get
# “can’t connect to localhost:5923”. Do not point production users at localhost.
# No trailing slash.
# VITE_OAUTH_REDIRECT_ORIGIN=http://localhost:5923
#
# Supabase: Authentication → URL configuration — Site URL + Redirect URLs must
# list every origin you use (https://blemmy.dev/**, http://localhost:5923/**,
# http://localhost:4173/** for vite preview, etc.).
# Google Cloud Console: OAuth client authorized redirect URIs must include your
# Supabase callback URLs (from Supabase provider docs), not only localhost.
